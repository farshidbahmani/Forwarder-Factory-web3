# Global deploy credentials (fallback if per-network keys are not set)
DEPLOYER_PRIVATE_KEY=0x...
RELAYER_PRIVATE_KEY=0x...

# Mother wallet address (should be a Multisig on mainnet)
MOTHER_WALLET=0x...

# Relayer address (backend server wallet)
RELAYER_ADDRESS=0x...

# Per-network example (BNB Testnet) — format: {NETWORK}_{KEY}
# BNB_TESTNET_DEPLOYER_PRIVATE_KEY=0x...
# BNB_TESTNET_DEPLOYER_ADDRESS=0x...
# BNB_TESTNET_RELAYER_PRIVATE_KEY=0x...
# BNB_TESTNET_RELAYER_ADDRESS=0x...
# BNB_TESTNET_MOTHER_PRIVATE_KEY=0x...
# BNB_TESTNET_MOTHER_WALLET=0x...
# BNB_TESTNET_FACTORY_ADDRESS=0x...

# RPC endpoints — explicitly tagged Mainnet/Testnet
BNB_MAINNET_RPC=https://bsc-dataseed1.bnbchain.org
BNB_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
OPBNB_MAINNET_RPC=https://opbnb-mainnet-rpc.bnbchain.org
ETHEREUM_MAINNET_RPC=https://eth.llamarpc.com
SEPOLIA_TESTNET_RPC=https://rpc.sepolia.org
POLYGON_MAINNET_RPC=https://polygon-rpc.com
POLYGON_AMOY_TESTNET_RPC=https://rpc-amoy.polygon.technology
ARBITRUM_MAINNET_RPC=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_TESTNET_RPC=https://sepolia-rollup.arbitrum.io/rpc
OPTIMISM_MAINNET_RPC=https://mainnet.optimism.io
OPTIMISM_SEPOLIA_TESTNET_RPC=https://sepolia.optimism.io
BASE_MAINNET_RPC=https://mainnet.base.org
BASE_SEPOLIA_TESTNET_RPC=https://sepolia.base.org
AVALANCHE_MAINNET_RPC=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_FUJI_TESTNET_RPC=https://api.avax-test.network/ext/bc/C/rpc

# Tron (gRPC endpoints — host:port)
TRON_MAINNET_RPC=grpc.trongrid.io:50051
TRON_SHASTA_RPC=grpc.shasta.trongrid.io:50051
TRONGRID_API_KEY=...   # optional, for higher rate limits

# Per-network Tron example (Shasta testnet)
# TRON_SHASTA_DEPLOYER_PRIVATE_KEY=0x...
# TRON_SHASTA_DEPLOYER_ADDRESS=T...
# TRON_SHASTA_RELAYER_PRIVATE_KEY=0x...
# TRON_SHASTA_RELAYER_ADDRESS=T...
# TRON_SHASTA_MOTHER_WALLET=T...
# TRON_SHASTA_FACTORY_ADDRESS=T...

# Block explorer API keys for verification
BSCSCAN_API_KEY=...
ETHERSCAN_API_KEY=...
POLYGONSCAN_API_KEY=...
ARBISCAN_API_KEY=...
OPTIMISM_API_KEY=...
BASESCAN_API_KEY=...
SNOWTRACE_API_KEY=...

# Foundry (optional — auto-detected from ~/.foundry/bin if not in PATH)
# FOUNDRY_BIN=/Users/you/.foundry/bin
# FORGE=/Users/you/.foundry/bin/forge
# CAST=/Users/you/.foundry/bin/cast
