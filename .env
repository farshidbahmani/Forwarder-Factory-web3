# کیف پول Deployer (فقط تستی، هرگز کیف پول واقعی نگذار)
DEPLOYER_PRIVATE_KEY=0x...

# آدرس مادر والت (روی mainnet باید Multisig باشه)
MOTHER_WALLET=0x...

# آدرس ریلایر (کیف پول سرور backend)
RELAYER_ADDRESS=0x...

# RPC های BSC
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
BSC_MAINNET_RPC=https://bsc-dataseed1.bnbchain.org

# کلید API بایننس‌اسکن برای verify کردن قراردادها
# از bscscan.com/myapikey بگیر (رایگانه)
BSCSCAN_API_KEY=...

# بعد از deploy، این رو پر کن (برای Backend)
FACTORY_ADDRESS=0x...
