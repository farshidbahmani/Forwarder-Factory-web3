{
  "name": "bnb-forwarder",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "compile":                "hardhat compile",
    "test":                   "hardhat test",
    "test:coverage":          "hardhat coverage",

    "wallet:create":          "ts-node scripts/createWallet.ts",
    "wallet:all-networks":    "ts-node scripts/createWallet.ts -- --all-networks",
    "wallet:list":            "ts-node scripts/createWallet.ts -- --list",
    "wallet:check":           "ts-node scripts/createWallet.ts -- --check",

    "deploy:bscTestnet":      "hardhat run scripts/deploy.ts --network bscTestnet",
    "deploy:bscMainnet":      "hardhat run scripts/deploy.ts --network bscMainnet",
    "deploy:opBNBMainnet":    "hardhat run scripts/deploy.ts --network opBNBMainnet",

    "deploy:sepoliaTestnet":  "hardhat run scripts/deploy.ts --network sepoliaTestnet",
    "deploy:ethereumMainnet": "hardhat run scripts/deploy.ts --network ethereumMainnet",

    "deploy:polygonAmoyTestnet": "hardhat run scripts/deploy.ts --network polygonAmoyTestnet",
    "deploy:polygonMainnet":  "hardhat run scripts/deploy.ts --network polygonMainnet",

    "deploy:arbitrumSepoliaTestnet": "hardhat run scripts/deploy.ts --network arbitrumSepoliaTestnet",
    "deploy:arbitrumMainnet": "hardhat run scripts/deploy.ts --network arbitrumMainnet",

    "deploy:optimismSepoliaTestnet": "hardhat run scripts/deploy.ts --network optimismSepoliaTestnet",
    "deploy:optimismMainnet": "hardhat run scripts/deploy.ts --network optimismMainnet",

    "deploy:baseSepoliaTestnet": "hardhat run scripts/deploy.ts --network baseSepoliaTestnet",
    "deploy:baseMainnet":     "hardhat run scripts/deploy.ts --network baseMainnet",

    "deploy:avalancheFujiTestnet": "hardhat run scripts/deploy.ts --network avalancheFujiTestnet",
    "deploy:avalancheMainnet": "hardhat run scripts/deploy.ts --network avalancheMainnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^20.0.0",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^16.4.5"
  }
}
